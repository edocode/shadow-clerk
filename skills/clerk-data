#!/bin/bash
# shadow-clerk データディレクトリ操作ラッパー
DATA_DIR="$HOME/.claude/skills/shadow-clerk/data"

# config.yaml から output_directory を読む（transcript-*/summary-* 用）
OUTPUT_DIR="$DATA_DIR"
CONFIG_FILE="$DATA_DIR/config.yaml"
if [ -f "$CONFIG_FILE" ]; then
  _out=$(grep '^output_directory:' "$CONFIG_FILE" 2>/dev/null | sed 's/^output_directory:[[:space:]]*//')
  if [ -n "$_out" ] && [ "$_out" != "null" ]; then
    OUTPUT_DIR="${_out/#\~/$HOME}"
    mkdir -p "$OUTPUT_DIR"
  fi
fi

# ファイル名に応じてディレクトリを解決する
# transcript-*/summary-* → OUTPUT_DIR、それ以外 → DATA_DIR
resolve_path() {
  case "$1" in
    transcript-*|summary-*) echo "$OUTPUT_DIR/$1" ;;
    *)                      echo "$DATA_DIR/$1" ;;
  esac
}

case "$1" in
  read)
    cat "$(resolve_path "$2")" 2>/dev/null
    ;;
  read-from)
    # read-from <filename> <byte_offset> — オフセット位置から読む
    dd if="$(resolve_path "$2")" bs=1 skip="$3" 2>/dev/null
    ;;
  write)
    # write <filename> <content>
    echo "$3" > "$(resolve_path "$2")"
    ;;
  append)
    # append <filename> [<content>]
    # append <filename> -f <source_file> — ファイルから読んで追記
    if [ "$3" = "-f" ] && [ -n "$4" ]; then
      cat "$4" >> "$(resolve_path "$2")"
    elif [ -n "$3" ]; then
      echo "$3" >> "$(resolve_path "$2")"
    else
      cat >> "$(resolve_path "$2")"
    fi
    ;;
  lines)
    wc -l < "$(resolve_path "$2")" 2>/dev/null
    ;;
  size)
    stat -c %s "$(resolve_path "$2")" 2>/dev/null
    ;;
  mtime)
    stat -c %y "$(resolve_path "$2")" 2>/dev/null
    ;;
  exists)
    [ -f "$(resolve_path "$2")" ] && echo "yes" || echo "no"
    ;;
  ls)
    ls -la "$DATA_DIR/" 2>/dev/null
    if [ "$OUTPUT_DIR" != "$DATA_DIR" ]; then
      echo ""
      echo "Output directory ($OUTPUT_DIR):"
      ls -la "$OUTPUT_DIR/" 2>/dev/null
    fi
    ;;
  command)
    # command <cmd> — .clerk_command に書き込み
    shift
    echo "$*" > "$DATA_DIR/.clerk_command"
    ;;
  recorder-status)
    # recorder-status — recorder.py の動作状態を表示
    if pgrep -f recorder.py > /dev/null 2>&1; then
      echo "running"
    else
      echo "stopped"
    fi
    ;;
  read-config)
    # read-config — config.yaml を読んで stdout に出力（なければデフォルト YAML を生成して出力）
    CONFIG_FILE="$DATA_DIR/config.yaml"
    if [ -f "$CONFIG_FILE" ]; then
      cat "$CONFIG_FILE"
    else
      DEFAULT_CONFIG="# shadow-clerk 設定
translate_language: ja
auto_translate: false
auto_summary: false
default_language: null
default_model: small
output_directory: null
llm_provider: claude
api_endpoint: null
api_model: null
api_key_env: SHADOW_CLERK_API_KEY
custom_commands: []
initial_prompt: null
voice_command_key: f23"
      echo "$DEFAULT_CONFIG" > "$CONFIG_FILE"
      cat "$CONFIG_FILE"
    fi
    ;;
  write-config)
    # write-config — stdin から config.yaml を書き込み
    cat > "$DATA_DIR/config.yaml"
    ;;
  path)
    # path — clerk-data 自身のフルパスを出力（setup 用）
    echo "$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    ;;
  *)
    echo "clerk-data — shadow-clerk データディレクトリ操作"
    echo ""
    echo "Usage: clerk-data <subcommand> [args]"
    echo ""
    echo "Subcommands:"
    echo "  read <file>            ファイルを読む"
    echo "  read-from <file> <offset> オフセット位置から読む"
    echo "  write <file> <text>    ファイルに書き込む"
    echo "  append <file> <text>   ファイルに追記する"
    echo "  lines <file>           行数を表示"
    echo "  size <file>            バイト数を表示"
    echo "  mtime <file>           最終更新日時を表示"
    echo "  exists <file>          ファイルの存在確認"
    echo "  ls                     データディレクトリの一覧"
    echo "  command <cmd>          recorder.py にコマンドを送信"
    echo "  recorder-status        recorder.py の動作状態 (running/stopped)"
    echo "  read-config            config.yaml を読む（なければデフォルト生成）"
    echo "  write-config           stdin から config.yaml を書き込む"
    echo ""
    echo "Data directory: $DATA_DIR"
    exit 1
    ;;
esac
